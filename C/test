#!/usr/bin/env python3

import sys
from pathlib import Path
from clang.cindex import Index, CursorKind


def linecol_to_offset(text, line, column):
    lines = text.splitlines(keepends=True)
    offset = 0
    for i in range(line - 1):
        if i < len(lines):
            offset += len(lines[i])
        else:
            break
    return offset + column - 1


def extract_source_text(path, start_line, start_col, end_line, end_col):
    try:
        text = path.read_text(encoding="utf-8")
    except Exception:
        return None
    start = linecol_to_offset(text, start_line, start_col)
    end = linecol_to_offset(text, end_line, end_col)
    return text[start:end].strip()


def flatten_enum(cursor):
    parts = ["enum"]
    if cursor.spelling:
        parts.append(" " + cursor.spelling)
    parts.append(" {\n")
    for child in cursor.get_children():
        if child.kind == CursorKind.ENUM_CONSTANT_DECL:
            val = child.enum_value
            parts.append(f"    {child.spelling} = {val},\n")
    parts.append("}")
    return "".join(parts)


def describe_cursor(cursor, depth=0, seen_offsets=None):
    if seen_offsets is None:
        seen_offsets = set()

    indent = "  " * depth
    kind = cursor.kind
    extent = cursor.extent
    start = extent.start
    end = extent.end

    loc = (start.file and start.file.name, start.line, start.column,
           end.line, end.column)
    if loc in seen_offsets:
        return
    seen_offsets.add(loc)

    print(f'{indent}{kind} "{cursor.spelling}"'
          f' linkage={cursor.linkage.name}'
          f' def={cursor.is_definition()}'
          f' loc={start.file and start.file.name}'
          f':{start.line}:{start.column}-{end.line}:{end.column}')

    if start.file:
        src = extract_source_text(
            Path(start.file.name), start.line, start.column,
            end.line, end.column,
        )
        if src:
            print(f"{indent}  src=[{src}]")

    for child in cursor.get_children():
        describe_cursor(child, depth + 1, seen_offsets)


class HeaderGenerator:
    def __init__(self):
        self.source_paths = []
        self.seen = set()
        self.types = []
        self.functions = []

    def in_source(self, cursor):
        if not cursor.location.file:
            return False
        loc = Path(cursor.location.file.name).resolve()
        return any(loc == p for p in self.source_paths)

    def make_function_proto(self, cursor):
        result_type = cursor.result_type.spelling
        name = cursor.spelling
        args = []
        for arg in cursor.get_arguments():
            arg_type = arg.type.spelling
            arg_name = arg.spelling
            if arg_name:
                args.append(f"{arg_type} {arg_name}")
            else:
                args.append(arg_type)
        arg_text = ", ".join(args) if args else "void"
        return f"{result_type} {name}({arg_text});"

    def visit(self, cursor):
        if not self.in_source(cursor):
            for child in cursor.get_children():
                self.visit(child)
            return

        kind = cursor.kind

        if kind == CursorKind.TYPEDEF_DECL:
            key = ("typedef", cursor.spelling)
            if key in self.seen:
                return
            self.seen.add(key)

            extent = cursor.extent
            start, end = extent.start, extent.end
            src = extract_source_text(
                Path(start.file.name), start.line, start.column,
                end.line, end.column,
            )
            if src:
                if not src.endswith(";"):
                    src += ";"
                self.types.append(src)

        elif kind == CursorKind.ENUM_DECL:
            if not cursor.is_definition():
                return
            key = ("enum", cursor.spelling)
            if key in self.seen:
                return
            loc_path = Path(cursor.location.file.name)
            try:
                lines = loc_path.read_text(encoding="utf-8").splitlines()
                prev_text = lines[cursor.location.line - 1][:cursor.location.column - 1]
                if prev_text.rstrip().endswith("typedef"):
                    return
            except Exception:
                pass
            self.seen.add(key)
            self.types.append(flatten_enum(cursor) + ";")

        elif kind == CursorKind.STRUCT_DECL:
            if not cursor.is_definition():
                return
            key = ("struct", cursor.spelling)
            if key in self.seen:
                return
            self.seen.add(key)

            extent = cursor.extent
            start, end = extent.start, extent.end
            src = extract_source_text(
                Path(start.file.name), start.line, start.column,
                end.line, end.column,
            )
            if src:
                if not src.endswith(";"):
                    src += ";"
                self.types.append(src)

        elif kind == CursorKind.UNION_DECL:
            if not cursor.is_definition():
                return
            key = ("union", cursor.spelling)
            if key in self.seen:
                return
            self.seen.add(key)

            extent = cursor.extent
            start, end = extent.start, extent.end
            src = extract_source_text(
                Path(start.file.name), start.line, start.column,
                end.line, end.column,
            )
            if src:
                if not src.endswith(";"):
                    src += ";"
                self.types.append(src)

        elif kind == CursorKind.FUNCTION_DECL:
            if cursor.linkage.name == "INTERNAL":
                return
            key = ("func", cursor.spelling)
            if key in self.seen:
                return
            self.seen.add(key)

            proto = self.make_function_proto(cursor)
            self.functions.append(proto)

        if kind != CursorKind.TYPEDEF_DECL:
            for child in cursor.get_children():
                self.visit(child)

    def parse(self, filename):
        path = Path(filename).resolve()
        self.source_paths.append(path)

        index = Index.create()
        tu = index.parse(
            str(filename),
            args=[
                "-std=c11",
                f"-I{path.parent}",
            ],
        )

        self.visit(tu.cursor)

    def write_header(self, output):
        guard = (
            Path(output)
            .name
            .upper()
            .replace(".", "_")
            .replace("-", "_")
        )

        with open(output, "w", encoding="utf-8") as f:
            f.write(f"#ifndef {guard}\n")
            f.write(f"#define {guard}\n\n")

            if self.types:
                f.write("/* Types */\n\n")
                for item in self.types:
                    f.write(item)
                    f.write("\n\n")

            if self.functions:
                f.write("/* Functions */\n\n")
                for fn in self.functions:
                    f.write(fn)
                    f.write("\n")
                f.write("\n")

            f.write(f"#endif /* {guard} */\n")


def main():
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help"):
        print(
            "Usage:\n"
            "  python generator.py output.h input1.c [input2.c ...]\n"
            "  python generator.py --inspect file.c\n"
        )
        sys.exit(0 if not args else 1)

    if args[0] in ("-i", "--inspect"):
        for src in args[1:]:
            path = Path(src)
            if not path.exists():
                print(f"File not found: {src}", file=sys.stderr)
                sys.exit(1)
            index = Index.create()
            tu = index.parse(
                str(src),
                args=["-std=c11", f"-I{path.parent}"],
            )
            describe_cursor(tu.cursor)
        return

    if len(args) < 2:
        print(
            "Usage:\n"
            "  python generator.py output.h input1.c [input2.c ...]\n"
            "  python generator.py --inspect file.c\n"
        )
        sys.exit(1)

    output = args[0]
    sources = args[1:]

    gen = HeaderGenerator()
    for src in sources:
        gen.parse(src)

    gen.write_header(output)
    print(f"Generated: {output}")


if __name__ == "__main__":
    main()
